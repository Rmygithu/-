# ============================================================
# 💔 心愈 AI - 环境变量配置模板
# ============================================================
# 使用说明：
#   1. 复制此文件为 .env：cp .env.example .env
#   2. 在 .env 文件中填入你的实际配置
#   3. ⚠️ 不要将 .env 文件提交到 Git！（已在 .gitignore 中排除）
# ============================================================

# ------------------------------------------------------------
# 🤖 MiMo 模型配置（必填）
# ------------------------------------------------------------
# API Key：从小米 AI 平台获取
# 获取地址：https://mimo.xiaomi.com/
MIMO_API_KEY=your_mimo_api_key_here

# API 端点地址（可选，有默认值）
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# 模型标识符（可选，有默认值）
MIMO_MODEL_ID=mimo-v2.5-pro

# ------------------------------------------------------------
# 🔧 高级配置（可选）
# ------------------------------------------------------------
# 日志级别：DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO

# Streamlit 服务器端口
# STREAMLIT_SERVER_PORT=8501

# ------------------------------------------------------------
# 💾 数据持久化配置（可选）
# ------------------------------------------------------------
# SQLite 数据库文件路径（默认：项目根目录/data/heartHeal.db）
# 用于保存用户对话历史、情绪评估结果、恢复计划等数据
# 页面关闭后再次打开可自动恢复上次会话
# SQLITE_DB_PATH=./data/heartHeal.db
